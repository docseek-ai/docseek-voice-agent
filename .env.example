# LiveKit Configuration
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your-api-key-here
LIVEKIT_API_SECRET=your-api-secret-here

# LLM Configuration
OPENAI_API_KEY=your-openai-api-key

# Speech Services
DEEPGRAM_API_KEY=your-deepgram-api-key
GOOGLE_API_KEY=your-google-api-key

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/docseek_voice

# Agent Configuration
AGENT_NAME=docseek-front-desk
AGENT_LOG_LEVEL=info

# ============================================================================
# CLINIC CONFIGURATION (RECOMMENDED WAY)
# ============================================================================
# Set CLINIC_ID to load complete clinic configuration
# (name, phone, address, all doctors, hours, insurance, etc.)
CLINIC_ID=sterling-family-medicine

# Optional: Focus on a specific doctor within the clinic
# Doctor IDs depend on which clinic is selected
# For sterling-family-medicine: dr-sarah-johnson, dr-michael-chen, np-emily-rodriguez
DOCTOR_ID=dr-sarah-johnson

# ============================================================================
# MANUAL CLINIC SETTINGS (fallback, used if CLINIC_ID not set)
# ============================================================================
# CLINIC_NAME=DocSeek Medical
# CLINIC_TIMEZONE=America/Chicago
# CLINIC_PHONE=+1-555-0123
